<%- include('../partials/layout-start', { title }) %>
<section class="content-grid two-column">
  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Profile Settings</h3>
        <p>Update account details and profile image.</p>
      </div>
    </div>
    <form action="/profile?_method=PUT" method="POST" enctype="multipart/form-data" class="form-grid">
      <div class="profile-avatar-large">
        <img src="<%= currentUser.profilePicture %>" alt="Profile">
      </div>
      <div class="form-group">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" value="<%= currentUser.name %>" required>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" value="<%= currentUser.email %>" required>
      </div>
      <div class="form-group">
        <label for="profilePicture">Profile Picture</label>
        <input id="profilePicture" name="profilePicture" type="file" accept="image/*">
      </div>
      <button type="submit" class="btn btn-primary btn-block">Save Profile</button>
    </form>
  </div>

  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Change Password</h3>
        <p>Verify the old password before saving a new one.</p>
      </div>
    </div>
    <form action="/profile/password?_method=PUT" method="POST" class="form-grid">
      <div class="form-group">
        <label for="oldPassword">Old Password</label>
        <input id="oldPassword" name="oldPassword" type="password" required>
      </div>
      <div class="form-group">
        <label for="newPassword">New Password</label>
        <input id="newPassword" name="newPassword" type="password" required>
      </div>
      <div class="form-group">
        <label for="confirmPassword">Confirm Password</label>
        <input id="confirmPassword" name="confirmPassword" type="password" required>
      </div>
      <button type="submit" class="btn btn-secondary btn-block">Update Password</button>
    </form>
  </div>
</section>
<%- include('../partials/layout-end') %>
