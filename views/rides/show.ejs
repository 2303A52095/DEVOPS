<%- include('../partials/layout-start', { title }) %>
<section class="content-grid two-column">
  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Ride Details</h3>
        <p>Complete booking summary and operational state.</p>
      </div>
      <% if (currentUser.role !== 'driver') { %>
        <a href="/rides/<%= ride._id %>/edit" class="btn btn-secondary">Edit Ride</a>
      <% } %>
    </div>

    <div class="detail-grid">
      <div class="detail-item">
        <span>Rider</span>
        <strong><%= ride.user?.name || 'N/A' %></strong>
      </div>
      <div class="detail-item">
        <span>Driver</span>
        <strong><%= ride.driver?.user?.name || 'Unassigned' %></strong>
      </div>
      <div class="detail-item">
        <span>Pickup</span>
        <strong><%= ride.pickupLocation %></strong>
      </div>
      <div class="detail-item">
        <span>Drop</span>
        <strong><%= ride.dropLocation %></strong>
      </div>
      <div class="detail-item">
        <span>Ride Type</span>
        <strong><%= ride.rideType %></strong>
      </div>
      <div class="detail-item">
        <span>Status</span>
        <strong><span class="status-pill status-<%= ride.status.toLowerCase() %>"><%= ride.status %></span></strong>
      </div>
      <div class="detail-item">
        <span>Date & Time</span>
        <strong><%= new Date(ride.rideDate).toLocaleString() %></strong>
      </div>
      <div class="detail-item">
        <span>Distance</span>
        <strong><%= ride.distanceKm %> km</strong>
      </div>
      <div class="detail-item">
        <span>Fare</span>
        <strong>₹<%= ride.fare %></strong>
      </div>
      <div class="detail-item">
        <span>Booked On</span>
        <strong><%= new Date(ride.createdAt).toLocaleString() %></strong>
      </div>
    </div>

    <% if (currentUser.role !== 'driver') { %>
      <div class="action-row">
        <% if (ride.status !== 'Cancelled') { %>
          <form action="/rides/<%= ride._id %>/cancel?_method=PATCH" method="POST" onsubmit="return confirm('Cancel this ride?')">
            <button type="submit" class="btn btn-warning">Cancel Ride</button>
          </form>
        <% } %>
        <form action="/rides/<%= ride._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this ride permanently?')">
          <button type="submit" class="btn btn-danger">Delete Ride</button>
        </form>
      </div>
    <% } %>
  </div>

  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Live Route</h3>
        <p>Pickup and drop preview for this ride.</p>
      </div>
    </div>
    <div id="rideMap" class="map-card" data-pickup='<%= JSON.stringify(ride.pickupCoordinates) %>' data-drop='<%= JSON.stringify(ride.dropCoordinates) %>'></div>
  </div>
</section>
<%- include('../partials/layout-end') %>
