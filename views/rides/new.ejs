<%- include('../partials/layout-start', { title }) %>
<section class="content-grid two-column">
  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Book a Ride</h3>
        <p>Create a new booking and auto-calculate fare from route distance.</p>
      </div>
    </div>
    <form action="/rides" method="POST" class="form-grid" id="rideForm">
      <div class="form-group">
        <label for="pickupLocation">Pickup Location</label>
        <input id="pickupLocation" name="pickupLocation" type="text" placeholder="MG Road, Bengaluru" required>
      </div>
      <div class="form-group">
        <label for="dropLocation">Drop Location</label>
        <input id="dropLocation" name="dropLocation" type="text" placeholder="Koramangala, Bengaluru" required>
      </div>
      <div class="form-group">
        <label for="rideType">Ride Type</label>
        <select id="rideType" name="rideType" required>
          <option value="Bike">Bike</option>
          <option value="Auto">Auto</option>
          <option value="Car">Car</option>
        </select>
      </div>
      <div class="form-group">
        <label for="rideDate">Date & Time</label>
        <input id="rideDate" name="rideDate" type="datetime-local" required>
      </div>
      <% if (currentUser.role === 'admin') { %>
        <div class="form-group">
          <label for="driverId">Assign Driver</label>
          <select id="driverId" name="driverId">
            <option value="">Auto Assign</option>
            <% drivers.forEach((driver) => { %>
              <option value="<%= driver._id %>"><%= driver.user.name %> - <%= driver.vehicleType %> - <%= driver.availability %></option>
            <% }) %>
          </select>
        </div>
      <% } %>
      <div class="fare-preview">
        <div>
          <span>Estimated Distance</span>
          <strong data-distance>0 km</strong>
        </div>
        <div>
          <span>Estimated Fare</span>
          <strong data-fare>₹0.00</strong>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Confirm Booking</button>
    </form>
  </div>

  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Trip Map</h3>
        <p>Visual route preview using OpenStreetMap tiles.</p>
      </div>
    </div>
    <div id="rideMap" class="map-card"></div>
  </div>
</section>
<%- include('../partials/layout-end') %>
