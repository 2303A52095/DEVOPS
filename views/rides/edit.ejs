<%- include('../partials/layout-start', { title }) %>
<section class="content-grid two-column">
  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Edit Ride</h3>
        <p>Update route, driver assignment, or ride status.</p>
      </div>
    </div>
    <form action="/rides/<%= ride._id %>?_method=PUT" method="POST" class="form-grid" id="rideForm">
      <div class="form-group">
        <label for="pickupLocation">Pickup Location</label>
        <input id="pickupLocation" name="pickupLocation" type="text" value="<%= ride.pickupLocation %>" required>
      </div>
      <div class="form-group">
        <label for="dropLocation">Drop Location</label>
        <input id="dropLocation" name="dropLocation" type="text" value="<%= ride.dropLocation %>" required>
      </div>
      <div class="form-group">
        <label for="rideType">Ride Type</label>
        <select id="rideType" name="rideType" required>
          <% ['Bike', 'Auto', 'Car'].forEach((type) => { %>
            <option value="<%= type %>" <%= ride.rideType === type ? 'selected' : '' %>><%= type %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="rideDate">Date & Time</label>
        <input id="rideDate" name="rideDate" type="datetime-local" value="<%= new Date(ride.rideDate).toISOString().slice(0, 16) %>" required>
      </div>
      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status" required>
          <% ['Pending', 'Accepted', 'Completed', 'Cancelled'].forEach((status) => { %>
            <option value="<%= status %>" <%= ride.status === status ? 'selected' : '' %>><%= status %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="driverId">Driver</label>
        <select id="driverId" name="driverId">
          <option value="">Unassigned</option>
          <% drivers.forEach((driver) => { %>
            <option value="<%= driver._id %>" <%= String(ride.driver || '') === String(driver._id) ? 'selected' : '' %>>
              <%= driver.user.name %> - <%= driver.vehicleType %> - <%= driver.availability %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="fare-preview">
        <div>
          <span>Estimated Distance</span>
          <strong data-distance><%= ride.distanceKm %> km</strong>
        </div>
        <div>
          <span>Estimated Fare</span>
          <strong data-fare>₹<%= ride.fare %></strong>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Save Changes</button>
    </form>
  </div>

  <div class="panel">
    <div class="panel-header">
      <div>
        <h3>Route Map</h3>
        <p>Verify pickup and destination visually.</p>
      </div>
    </div>
    <div id="rideMap" class="map-card" data-pickup='<%= JSON.stringify(ride.pickupCoordinates) %>' data-drop='<%= JSON.stringify(ride.dropCoordinates) %>'></div>
  </div>
</section>
<%- include('../partials/layout-end') %>
