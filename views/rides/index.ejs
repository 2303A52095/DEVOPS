<%- include('../partials/layout-start', { title }) %>
<section class="panel">
  <div class="panel-header">
    <div>
      <h3>Ride Management</h3>
      <p>Search, sort, and manage booking records.</p>
    </div>
    <% if (currentUser.role !== 'driver') { %>
      <a href="/rides/new" class="btn btn-primary">Create Booking</a>
    <% } %>
  </div>

  <form method="GET" action="/rides" class="toolbar">
    <div class="toolbar-group">
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search locations, type, status">
      <select name="status">
        <option value="">All Statuses</option>
        <% ['Pending', 'Accepted', 'Completed', 'Cancelled'].forEach((status) => { %>
          <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
        <% }) %>
      </select>
      <select name="rideType">
        <option value="">All Types</option>
        <% ['Bike', 'Auto', 'Car'].forEach((type) => { %>
          <option value="<%= type %>" <%= filters.rideType === type ? 'selected' : '' %>><%= type %></option>
        <% }) %>
      </select>
      <select name="sort">
        <option value="createdAt" <%= sortField === 'createdAt' ? 'selected' : '' %>>Newest</option>
        <option value="fare" <%= sortField === 'fare' ? 'selected' : '' %>>Fare</option>
        <option value="rideDate" <%= sortField === 'rideDate' ? 'selected' : '' %>>Ride Date</option>
      </select>
      <select name="order">
        <option value="desc" <%= sortOrder === -1 ? 'selected' : '' %>>Descending</option>
        <option value="asc" <%= sortOrder === 1 ? 'selected' : '' %>>Ascending</option>
      </select>
    </div>
    <button type="submit" class="btn btn-secondary">Apply</button>
  </form>

  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th>Rider</th>
          <th>Pickup</th>
          <th>Drop</th>
          <th>Type</th>
          <th>Date</th>
          <th>Fare</th>
          <th>Status</th>
          <th>Driver</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (rides.length) { %>
          <% rides.forEach((ride) => { %>
            <tr>
              <td><%= ride.user?.name || 'N/A' %></td>
              <td><%= ride.pickupLocation %></td>
              <td><%= ride.dropLocation %></td>
              <td><%= ride.rideType %></td>
              <td><%= new Date(ride.rideDate).toLocaleString() %></td>
              <td>₹<%= ride.fare %></td>
              <td><span class="status-pill status-<%= ride.status.toLowerCase() %>"><%= ride.status %></span></td>
              <td><%= ride.driver?.user?.name || 'Unassigned' %></td>
              <td class="table-actions">
                <a href="/rides/<%= ride._id %>" class="btn btn-ghost">View</a>
                <% if (currentUser.role !== 'driver') { %>
                  <a href="/rides/<%= ride._id %>/edit" class="btn btn-ghost">Edit</a>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="9" class="empty-cell">No rides match the current filters.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/layout-end') %>
