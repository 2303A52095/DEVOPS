<%- include('../partials/layout-start', { title }) %>
<section class="panel">
  <div class="panel-header">
    <div>
      <h3>User Management</h3>
      <p>Manage platform users, access roles, and login activity.</p>
    </div>
  </div>

  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Last Login</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length) { %>
          <% users.forEach((user) => { %>
            <tr>
              <td class="user-cell">
                <img src="<%= user.profilePicture %>" alt="Avatar">
                <span><%= user.name %></span>
              </td>
              <td><%= user.email %></td>
              <td>
                <form action="/users/<%= user._id %>/role?_method=PATCH" method="POST" class="inline-form">
                  <select name="role" onchange="this.form.submit()">
                    <% ['user', 'driver', 'admin'].forEach((role) => { %>
                      <option value="<%= role %>" <%= user.role === role ? 'selected' : '' %>><%= role %></option>
                    <% }) %>
                  </select>
                </form>
              </td>
              <td><%= user.lastLogin ? new Date(user.lastLogin).toLocaleString() : 'Never' %></td>
              <td>
                <form action="/users/<%= user._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this user?')">
                  <button type="submit" class="btn btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="empty-cell">No users found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/layout-end') %>
