<%- include('../partials/layout-start', { title }) %>
<section class="dashboard-grid">
  <div class="stats-grid">
    <article class="stat-card">
      <span>Total Rides</span>
      <strong><%= metrics.totalRides %></strong>
      <i class="fa-solid fa-route"></i>
    </article>
    <article class="stat-card">
      <span>Total Users</span>
      <strong><%= metrics.totalUsers %></strong>
      <i class="fa-solid fa-users"></i>
    </article>
    <article class="stat-card">
      <span>Total Drivers</span>
      <strong><%= metrics.totalDrivers %></strong>
      <i class="fa-solid fa-id-card"></i>
    </article>
    <article class="stat-card">
      <span>Active Bookings</span>
      <strong><%= metrics.activeBookings %></strong>
      <i class="fa-solid fa-bolt"></i>
    </article>
  </div>

  <div class="panel chart-panel">
    <div class="panel-header">
      <div>
        <h3>Rides Per Month</h3>
        <p>Volume distribution across the year.</p>
      </div>
    </div>
    <canvas
      id="ridesBarChart"
      data-labels="<%= JSON.stringify(chartData.months) %>"
      data-values="<%= JSON.stringify(chartData.ridesPerMonth) %>"></canvas>
  </div>

  <div class="panel chart-panel">
    <div class="panel-header">
      <div>
        <h3>Ride Type Mix</h3>
        <p>Split by vehicle type.</p>
      </div>
    </div>
    <canvas
      id="ridesPieChart"
      data-labels="<%= JSON.stringify(chartData.rideTypes) %>"
      data-values="<%= JSON.stringify(chartData.rideTypeCounts) %>"></canvas>
  </div>

  <div class="panel table-panel full-width">
    <div class="panel-header">
      <div>
        <h3>Recent Rides</h3>
        <p>Latest booking activity.</p>
      </div>
      <a href="/rides/new" class="btn btn-primary">Book Ride</a>
    </div>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Rider</th>
            <th>Trip</th>
            <th>Driver</th>
            <th>Type</th>
            <th>Status</th>
            <th>Fare</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentRides.length) { %>
            <% recentRides.forEach((ride) => { %>
              <tr>
                <td><%= ride.user?.name || 'N/A' %></td>
                <td><%= ride.pickupLocation %> to <%= ride.dropLocation %></td>
                <td><%= ride.driver?.user?.name || 'Unassigned' %></td>
                <td><%= ride.rideType %></td>
                <td><span class="status-pill status-<%= ride.status.toLowerCase() %>"><%= ride.status %></span></td>
                <td>₹<%= ride.fare %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="empty-cell">No ride data available yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<%- include('../partials/layout-end') %>
