<aside class="sidebar <%= !currentUser ? 'hidden' : '' %>" id="sidebar">
  <div class="brand">
    <div class="brand-mark">NG</div>
    <div>
      <h1>NexGoRide</h1>
      <p>Mobility Suite</p>
    </div>
  </div>

  <% if (currentUser) { %>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="<%= currentPath.startsWith('/dashboard') ? 'active' : '' %>">
        <i class="fa-solid fa-chart-line"></i>
        <span>Dashboard</span>
      </a>
      <a href="/rides" class="<%= currentPath.startsWith('/rides') ? 'active' : '' %>">
        <i class="fa-solid fa-car-side"></i>
        <span>Rides</span>
      </a>
      <% if (currentUser.role === 'admin') { %>
        <a href="/users" class="<%= currentPath.startsWith('/users') ? 'active' : '' %>">
          <i class="fa-solid fa-users"></i>
          <span>Users</span>
        </a>
        <a href="/drivers" class="<%= currentPath.startsWith('/drivers') ? 'active' : '' %>">
          <i class="fa-solid fa-id-card"></i>
          <span>Drivers</span>
        </a>
      <% } %>
      <a href="/profile" class="<%= currentPath.startsWith('/profile') ? 'active' : '' %>">
        <i class="fa-solid fa-user-gear"></i>
        <span>Profile</span>
      </a>
    </nav>
  <% } %>
</aside>
