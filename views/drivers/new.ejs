<%- include('../partials/layout-start', { title }) %>
<section class="panel form-panel">
  <div class="panel-header">
    <div>
      <h3>Add Driver</h3>
      <p>Create driver credentials and fleet details in one step.</p>
    </div>
  </div>
  <form action="/drivers" method="POST" class="form-grid">
    <div class="form-group">
      <label for="name">Name</label>
      <input id="name" name="name" type="text" required>
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required>
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required>
    </div>
    <div class="form-group">
      <label for="licenseNumber">License Number</label>
      <input id="licenseNumber" name="licenseNumber" type="text" required>
    </div>
    <div class="form-group">
      <label for="vehicleType">Vehicle Type</label>
      <select id="vehicleType" name="vehicleType" required>
        <option value="Bike">Bike</option>
        <option value="Auto">Auto</option>
        <option value="Car">Car</option>
      </select>
    </div>
    <div class="form-group">
      <label for="vehicleNumber">Vehicle Number</label>
      <input id="vehicleNumber" name="vehicleNumber" type="text" required>
    </div>
    <div class="form-group">
      <label for="availability">Availability</label>
      <select id="availability" name="availability" required>
        <option value="available">available</option>
        <option value="busy">busy</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary btn-block">Create Driver</button>
  </form>
</section>
<%- include('../partials/layout-end') %>
